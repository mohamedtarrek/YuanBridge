generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIALING
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  PENDING
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum StrategyDirection {
  BUY
  SELL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TrendDirection {
  BULLISH
  BEARISH
  NEUTRAL
}

enum AIJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AIProvider {
  OPENAI
  CLAUDE
  GEMINI
  DEEPSEEK
}

enum NotificationType {
  STRATEGY
  SYSTEM
  BILLING
  ALERT
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id              String           @id @default(cuid())
  name            String?
  nameAr          String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            UserRole         @default(USER)
  language        String           @default("ar")
  theme           String           @default("dark")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  emailNotifications   Boolean @default(true)
  pushNotifications    Boolean @default(true)
  telegramNotifications Boolean @default(false)
  telegramChatId       String?

  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  payments       Payment[]
  favorites      Favorite[]
  savedStrategies SavedStrategy[]
  notifications  Notification[]
  loginHistory   LoginHistory[]

  @@map("users")
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String             @unique
  plan          SubscriptionPlan   @default(FREE)
  status        SubscriptionStatus @default(TRIALING)
  startedAt     DateTime           @default(now())
  endsAt        DateTime?
  cancelledAt   DateTime?
  stripeId      String?
  stripePriceId String?
  stripeSubId   String?
  paypalSubId   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("subscriptions")
}

model Payment {
  id             String          @id @default(cuid())
  userId         String
  subscriptionId String
  amount         Float
  currency       String          @default("USD")
  status         PaymentStatus   @default(PENDING)
  provider       PaymentProvider
  providerId     String?
  invoiceUrl     String?
  createdAt      DateTime        @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

model Strategy {
  id                  String             @id @default(cuid())
  title               String
  titleAr             String
  currencyPair        String
  direction           StrategyDirection
  entryPrice          Float
  stopLoss            Float
  takeProfit1         Float
  takeProfit2         Float
  risk                RiskLevel
  confidence          Float
  summary             String
  summaryAr           String
  isPremium           Boolean            @default(false)
  isPublished         Boolean            @default(false)
  isApproved          Boolean            @default(false)

  technicalAnalysis   String?
  technicalAnalysisAr String?
  fundamentalAnalysis  String?
  fundamentalAnalysisAr String?
  trend               TrendDirection
  support1            Float?
  support2            Float?
  support3            Float?
  resistance1         Float?
  resistance2         Float?
  resistance3         Float?

  rsi                 Float?
  macdValue           Float?
  macdSignal          Float?
  macdHistogram       Float?
  emaFast             Float?
  emaSlow             Float?
  smaPeriod           Int?
  smaValue            Float?
  atr                 Float?
  bbUpper             Float?
  bbMiddle            Float?
  bbLower             Float?

  notes               String?
  notesAr             String?
  tradesAnalyzed      Int                @default(0)
  aiModel             String?
  aiProvider          AIProvider?
  aiJobId             String?
  publishedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  favorites     Favorite[]
  savedBy       SavedStrategy[]
  aiJob         AIJob?           @relation(fields: [aiJobId], references: [id])
  logs          AIJobLog[]

  @@index([currencyPair])
  @@index([direction])
  @@index([risk])
  @@index([confidence])
  @@index([isPremium])
  @@index([isPublished])
  @@index([createdAt])
  @@map("strategies")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  strategyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([userId, strategyId])
  @@map("favorites")
}

model SavedStrategy {
  id         String   @id @default(cuid())
  userId     String
  strategyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([userId, strategyId])
  @@map("saved_strategies")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  titleAr   String
  message   String
  messageAr String
  type      NotificationType
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model AIJob {
  id          String       @id @default(cuid())
  status      AIJobStatus  @default(PENDING)
  provider    AIProvider
  model       String?
  prompt      String?
  result      String?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  strategies Strategy[]
  logs       AIJobLog[]

  @@map("ai_jobs")
}

model AIJobLog {
  id         String   @id @default(cuid())
  jobId      String
  level      String   @default("INFO")
  message    String
  strategyId String?
  createdAt  DateTime @default(now())

  job      AIJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  strategy Strategy? @relation(fields: [strategyId], references: [id])

  @@map("ai_job_logs")
}

model MarketData {
  id        String   @id @default(cuid())
  pair      String
  price     Float
  volume    Float
  high24h   Float
  low24h    Float
  change24h Float
  source    String   @default("internal")
  timestamp DateTime @default(now())

  @@index([pair, timestamp])
  @@map("market_data")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  nameAr    String
  role      String
  roleAr    String
  content   String
  contentAr String
  rating    Int      @default(5)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model FAQ {
  id        String @id @default(cuid())
  question  String
  questionAr String
  answer    String
  answerAr  String
  order     Int    @default(0)
  active    Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("app_settings")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_history")
}

model Report {
  id          String   @id @default(cuid())
  userId      String?
  type        String
  data        String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("reports")
}
