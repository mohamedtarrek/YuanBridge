# ──────────────────────────────────────────────
# DATABASE (Neon PostgreSQL)
# ──────────────────────────────────────────────
# DATABASE_URL must use the pooled endpoint (contains "-pooler" in the hostname).
# This enables PgBouncer connection pooling for serverless/lambda runtimes.
# Required on: Local, Vercel, all environments.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/database?sslmode=require&pgbouncer=true"

# DIRECT_URL must use the direct (non-pooled) endpoint (NO "-pooler" in hostname).
# Prisma Migrate / db push / generate require a direct connection because
# PgBouncer does not support prepared statements, DDL, or advisory locks.
# Required on: Local, Vercel, all environments.
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/database?sslmode=require"

# ──────────────────────────────────────────────
# AUTHENTICATION (Auth.js / NextAuth v5)
# ──────────────────────────────────────────────
# Generate a strong random secret:  openssl rand -hex 32  |  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required on: Local, Vercel, all environments.
AUTH_SECRET=

# Set to your Vercel deployment URL (e.g., https://yuanbridge.vercel.app)
# Required on: Vercel.  Not needed locally (Next.js detects localhost).
AUTH_URL=
NEXTAUTH_URL=

# Set to "1" when running on Vercel or any production domain.
# Required on: Vercel.
AUTH_TRUST_HOST=1

# ──────────────────────────────────────────────
# PAYMENT PROVIDERS (Coming Soon)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ──────────────────────────────────────────────
# AI PROVIDERS (Coming Soon)
# ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=

# ──────────────────────────────────────────────
# NOTIFICATIONS
# ──────────────────────────────────────────────
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yuanbridge.com

VAPID_SUBJECT=mailto:support@yuanbridge.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
# On Vercel: set to your production URL (e.g., https://yuanbridge.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
