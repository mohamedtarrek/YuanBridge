# Database (Neon)
# IMPORTANT: Use pooler URL with ?pgbouncer=true for runtime queries
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/database?sslmode=require&pgbouncer=true"
# DIRECT_URL must be the direct (non-pooler) connection for migrations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/database?sslmode=require"

# Authentication (Auth.js / NextAuth v5)
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# On Vercel, set this to your production URL (e.g., https://your-app.vercel.app)
AUTH_URL=
NEXTAUTH_URL=
AUTH_TRUST_HOST=1

# Payment Providers (Coming Soon)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# AI Providers (Coming Soon)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=

# Notifications
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
