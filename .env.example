# ──────────────────────────────────────────────
# REQUIRED — Authentication will fail without these
# ──────────────────────────────────────────────

# Neon PostgreSQL connection string (direct endpoint, no "-pooler").
# Used by Prisma for both runtime queries AND migrations.
# Required on: Local, Vercel.
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/database?sslmode=require"

# Used by Auth.js to encrypt JWTs and cookies. Generate with: openssl rand -hex 32
# Required on: Local, Vercel.
AUTH_SECRET=

# ──────────────────────────────────────────────
# RECOMMENDED for Vercel — URL construction
# ──────────────────────────────────────────────

# Your Vercel deployment URL (e.g., https://yuanbridge.vercel.app).
# Auth.js uses this to build correct callback URLs. On Vercel, the host header
# is usually correct, but setting this explicitly prevents edge cases.
# Required on: Vercel (recommended).  Localhost auto-detects.
AUTH_URL=

# ──────────────────────────────────────────────
# OPTIONAL — OAuth providers
# ──────────────────────────────────────────────

# Google OAuth credentials (only needed if Google sign-in is enabled).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth credentials (only needed if GitHub sign-in is enabled).
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ──────────────────────────────────────────────
# OPTIONAL — Payment providers
# ──────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ──────────────────────────────────────────────
# OPTIONAL — AI providers
# ──────────────────────────────────────────────

OPENAI_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
YOUTUBE_API_KEY=

# ──────────────────────────────────────────────
# OPTIONAL — Notifications
# ──────────────────────────────────────────────

RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Has default "noreply@yuanbridge.com" in code. Set only to override.
EMAIL_FROM=noreply@yuanbridge.com

# Has default "mailto:support@yuanbridge.com" in code. Set only to override.
VAPID_SUBJECT=mailto:support@yuanbridge.com

# ──────────────────────────────────────────────
# OPTIONAL — Cron / Scheduled jobs
# ──────────────────────────────────────────────

CRON_SECRET=

# ──────────────────────────────────────────────
# OPTIONAL — Public app URL
# ──────────────────────────────────────────────

# Used for payment redirect URLs and notification links.
# On Vercel: set to your production URL (e.g., https://yuanbridge.vercel.app)
# Defaults to http://localhost:3000 if not set.
NEXT_PUBLIC_APP_URL=http://localhost:3000
